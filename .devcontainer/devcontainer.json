{
  "name": "PayOn Laravel Environment",
  "image": "mcr.microsoft.com/devcontainers/php:8.2-bullseye",

  "forwardPorts": [8000, 3306, 6379, 5173],

  "postCreateCommand": "sudo service mysql start && sudo service redis-server start && composer install || true && npm install || true",

  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "onecentlin.laravel-blade",
        "amiralizadeh9480.laravel-extra-intellisense",
        "ryannaddy.laravel-artisan",
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },

  "remoteUser": "vscode"
}
